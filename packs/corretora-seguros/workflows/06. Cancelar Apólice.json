    {
      "parameters": {
        "jsCode": "/**\n * Monta a nova descrição da tarefa marcando o pedido de cancelamento.\n * Preserva a descrição existente (nunca sobrescreve cegamente).\n */\nconst task = $input.first().json;\nconst input = $('Gatilho').first().json;\nconst attrs = task.custom_attributes ?? {};\n\nconst temApolice = Boolean(attrs.numero_apolice);\nconst cabecalho = temApolice\n  ? `Cancelamento solicitado da apólice *${attrs.numero_apolice}* (${attrs.operadora ?? 'operadora não informada'}).`\n  : `Cancelamento solicitado (apólice ainda não emitida nesta tarefa).`;\n\nconst descricaoAtual = task.description ?? '';\nconst bloco = [\n  '---',\n  '🛑 *Cancelamento solicitado*',\n  `Em: ${DateTime.now().toISO()}`,\n  `Motivo: ${input.motivo || 'não informado'}`,\n  cabecalho\n].join('\\n');\n\nconst novaDescricao = descricaoAtual\n  ? `${descricaoAtual}\\n\\n${bloco}`\n  : bloco;\n\n// Resumo da conversa (passado para o escalar_humano)\nconst resumoConversa = [\n  `Cliente solicitou cancelamento.`,\n  temApolice ? `Apólice: ${attrs.numero_apolice} (${attrs.operadora}).` : `Tarefa sem apólice emitida.`,\n  `Motivo: ${input.motivo || 'não informado'}.`\n].join(' ');\n\nreturn [{\n  json: {\n    account_id: input.account_id,\n    conversation_id: input.conversation_id,\n    inbox_id: input.inbox_id,\n    task_id: input.task_id,\n    motivo: input.motivo,\n    nome: input.nome,\n    telefone: input.telefone,\n    nova_descricao: novaDescricao,\n    resumo_conversa: resumoConversa,\n    numero_apolice: attrs.numero_apolice,\n    operadora: attrs.operadora,\n    tem_apolice: temApolice\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
